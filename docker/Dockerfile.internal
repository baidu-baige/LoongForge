ARG BASE_IMAGE="registry.baidubce.com/aiak-training-ns/nvidia/pytorch:25.06-py3-deepspeed0.17.6"
FROM ${BASE_IMAGE}

# =========================================================
# Build Arguments
# =========================================================
ARG COMPILE_ENV={{COMPILE_ENV}}
# Do not change this here; set INSTALL_LEROBOT in the ipipe pipeline configuration.
ARG INSTALL_LEROBOT="false"

# =========================================================
# Environment Variables
# =========================================================
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /workspace

# =========================================================
# Base System Configuration + APT Source Replacement
# =========================================================
COPY ./AIAK-Training-Omni /workspace/OmniTraining
COPY ./AIAK-Megatron /workspace/AIAK-Megatron
COPY ./TransformerEngine /workspace/TransformerEngine

# ======================== Basic Environment Setup ========================
RUN set -exuo pipefail && \
    clean_pip_config() { \
        rm -rf /opt/conda/pip.conf /root/.config/pip/pip.conf /root/.pip/pip.conf \
            /etc/pip.conf /etc/xdg/pip/pip.conf /usr/pip.conf; \
    }; \
    install_pip_config() { \
        mkdir -p /tmp && chmod -R 777 /tmp && \
        if [ -f /workspace/OmniTraining/docker/pip.conf ]; then \
            cp /workspace/OmniTraining/docker/pip.conf /etc/pip.conf && \
            cp /workspace/OmniTraining/docker/pip.conf /usr/pip.conf && \
            mkdir -p /root/.pip && cp /workspace/OmniTraining/docker/pip.conf /root/.pip/pip.conf && \
            mkdir -p /etc/xdg/pip && cp /workspace/OmniTraining/docker/pip.conf /etc/xdg/pip/pip.conf; \
        fi; \
    }; \
    remove_pip_constraints() { \
        source_file="/etc/pip/constraint.txt" && \
        if [ -f "${source_file}" ]; then \
            backup_file="${source_file%.*}_backup.${source_file##*.}" && \
            mv -v "${source_file}" "${backup_file}" && \
            > "${source_file}"; \
        fi; \
    }; \
    setup_system_env() { \
        if [ -f /workspace/OmniTraining/docker/sources.list ]; then \
            rm -rf /etc/apt/sources.list && \
            cp /workspace/OmniTraining/docker/sources.list /etc/apt/sources.list; \
        fi && \
        rm -f /etc/apt/sources.list.d/ubuntu.sources && \
        apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y tzdata && \
        ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
        apt-get install -y bc tree pwgen nodejs iproute2; \
    }; \
    clean_pip_config && \
    install_pip_config && \
    remove_pip_constraints && \
    setup_system_env

# ======================== Install Base Requirements ========================
RUN set -exuo pipefail && \
    install_requirements() { \
        local requirements_file="/workspace/OmniTraining/requirements_internal.txt"; \
        cd /workspace/OmniTraining/ && \
        pip install -q --no-cache-dir --root-user-action=ignore -r ${requirements_file} \
            -i http://mirrors.baidubce.com/pypi/simple --trusted-host mirrors.baidubce.com; \
    }; \
    install_requirements && \
    echo "y" | pip uninstall nvidia-modelopt || true

# =========================================================
# Specific Environment Setup
# =========================================================
RUN set -exuo pipefail && \
    update_flash_attn3_path_for_te() { \
        echo "Updating Flash Attention 3 import path for TE..." && \
        python_path=$(python -c "import site; print(site.getsitepackages()[0])") && \
        mkdir -p ${python_path}/flash_attn_3/ && \
        if [ -f "${python_path}/flash_attn_interface.py" ]; then \
            cp ${python_path}/flash_attn_interface.py ${python_path}/flash_attn_3/ && \
            echo "Flash Attention 3 adapter installed successfully!"; \
        else \
            echo "Warning: flash_attn_interface.py not found"; \
        fi; \
    }; \
    install_deepep() { \
        local torch_cuda_arch_list="$1"; \
        local disable_sm90="$2" && \
        echo "Installing DeepEP (internal version)..." && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/bzz_deepep/nvshmem.tar.gz && \
        tar -zxf nvshmem.tar.gz && \
        cp -rf nvshmem /usr/local/nvshmem && \
        export NVSHMEM_DIR=/usr/local/nvshmem; \
        export LD_LIBRARY_PATH=${NVSHMEM_DIR}/lib:${LD_LIBRARY_PATH}; \
        export PATH=${NVSHMEM_DIR}/bin:${PATH} && \
        rm -rf nvshmem nvshmem.tar.gz && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/bzz_deepep/deep_ep-1.2.1+9af0e0d-cp312-cp312-linux_x86_64.whl && \
        TORCH_CUDA_ARCH_LIST="${torch_cuda_arch_list}" DISABLE_SM90_FEATURES="${disable_sm90}" pip install deep_ep-1.2.1+9af0e0d-cp312-cp312-linux_x86_64.whl && \
        rm -rf deep_ep-1.2.1+9af0e0d-cp312-cp312-linux_x86_64.whl; \
    }; \
    upgrade_cudnn_9_16_0() { \
        echo "Upgrading cuDNN to 9.16.0..." && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/cudnn-local-repo-ubuntu2404-9.16.0_1.0-1_amd64.deb && \
        dpkg -i cudnn-local-repo-ubuntu2404-9.16.0_1.0-1_amd64.deb && \
        cp /var/cudnn-local-repo-ubuntu2404-9.16.0/cudnn-*-keyring.gpg /usr/share/keyrings/ && \
        apt-get update && \
        apt-get -y install cudnn9-cuda-12 && \
        dpkg -l | grep cudnn && \
        rm -f cudnn-local-repo-ubuntu2404-9.16.0_1.0-1_amd64.deb && \
        rm -rf /var/lib/apt/lists/*; \
    }; \
    install_aiak_fp8_quant() { \
        echo "Installing AIAK FP8 Quantization..." && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/AIAK-FP8-Quantization.tar.gz && \
        tar -zxf AIAK-FP8-Quantization.tar.gz && \
        cd AIAK-FP8-Quantization && \
        python setup.py clean && \
        python setup.py build_ext --inplace --force && \
        pip install . && \
        cd .. && \
        rm -rf AIAK-FP8-Quantization AIAK-FP8-Quantization.tar.gz; \
    }; \
    install_deepgemm() { \
        echo "Installing DeepGEMM..." && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/DeepGEMM.tar.gz && \
        tar -zxf DeepGEMM.tar.gz && \
        cd DeepGEMM && \
        git status && \
        git reset --hard HEAD && \
        git submodule foreach --recursive 'git reset --hard HEAD || true' && \
        git submodule foreach --recursive 'git clean -fdx || true' && \
        git clean -fdx && \
        pip install -v . && \
        cd .. && \
        rm -rf DeepGEMM DeepGEMM.tar.gz; \
    }; \
    install_flashmla() { \
        echo "Installing FlashMLA..." && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/FlashMLA.tar.gz && \
        tar -zxf FlashMLA.tar.gz && \
        pip install -v ./FlashMLA; \
        rm -rf FlashMLA FlashMLA.tar.gz; \
    }; \
    update_flash_attn3_path_for_te && \
    install_aiak_fp8_quant && \
    upgrade_cudnn_9_16_0 && \
    install_deepgemm && \
    install_flashmla && \
    if [ "${COMPILE_ENV}" = "ampere" ]; then \
        install_deepep "8.0" "1"; \
    elif [ "${COMPILE_ENV}" = "hopper" ]; then \
        install_deepep "9.0" "0"; \
    elif [ "${COMPILE_ENV}" = "blackwell" ]; then \
        install_deepep "10.0" "0"; \
    else \
        echo "[ERROR] Unsupported COMPILE_ENV value: ${COMPILE_ENV}" && \
        exit 1; \
    fi

# =========================================================
# TransformerEngine / Megatron / Lerobot
# =========================================================
RUN set -exuo pipefail && \
    install_transformer_engine() { \
        local transformerEngine_dir=/workspace/TransformerEngine; \
        local TE_TAGS="v2.9" && \
        echo "Installing TransformerEngine ${TE_TAGS}..." && \
        cd ${transformerEngine_dir} && \
        local thirdparty_path="${transformerEngine_dir}/3rdparty" && \
        rm -rf ${thirdparty_path} && \
        mkdir -p ${thirdparty_path} && \
        cd ${thirdparty_path} && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/cudnn-frontend.tar.gz && \
        tar -zxf cudnn-frontend.tar.gz && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/cutlass.tar.gz && \
        tar -zxf cutlass.tar.gz && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/googletest.tar.gz && \
        tar -zxf googletest.tar.gz && \
        rm -rf cudnn-frontend.tar.gz cutlass.tar.gz googletest.tar.gz && \
        cd ${transformerEngine_dir} && \
        pip install nvidia-mathdx==25.1.1 -i http://mirrors.baidubce.com/pypi/simple --trusted-host mirrors.baidubce.com && \
        ABI=$(python -c "import torch; print(int(torch._C._GLIBCXX_USE_CXX11_ABI))") && \
        export CXXFLAGS="-D_GLIBCXX_USE_CXX11_ABI=${ABI}" && \
        export NVTE_WITH_USERBUFFERS=1 && \
        export MPI_HOME=/usr/local/mpi && \
        export NVTE_FRAMEWORK=pytorch && \
        pip3 install --no-build-isolation . && \
        echo "TransformerEngine install completed" && \
        cd /workspace && rm -rf ${transformerEngine_dir}; \
    }; \
    install_megatron() { \
        local megatron_dir=/workspace/AIAK-Megatron; \
        local MEGATRON_TAGS="core_v0.15.0" && \
        echo "Installing Megatron-LM ${MEGATRON_TAGS}..." && \
        cd ${megatron_dir} && \
        echo "Megatron-LM setup completed"; \
    }; \
    install_lerobot() { \
        echo "Installing lerobot..." && \
        cd /workspace && \
        if [ -d "lerobot" ]; then \
            rm -rf lerobot; \
        fi && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/lerobot.tar.gz && \
        tar -zxf lerobot.tar.gz && \
        cd lerobot && \
        if [ -f "requirements-ubuntu.txt" ]; then \
            sed -i '/evdev/d' requirements-ubuntu.txt; \
        fi && \
        pip install "numpy==1.26" && \
        pip install "transformers@http://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/aiak-training-llm/transformers-fix-lerobot_openpi-20251001-dcddb970.tar.gz" && \
        pip install --no-build-isolation . && \
        echo "Lerobot installation completed"; \
    }; \
    install_transformer_engine && \
    install_megatron && \
    if [ "$INSTALL_LEROBOT" = "true" ]; then \
        install_lerobot; \
    else \
        echo "Skipping lerobot installation (INSTALL_LEROBOT=${INSTALL_LEROBOT})"; \
    fi

# =========================================================
# Jupyter Configuration
# =========================================================
RUN mkdir -p /root/.jupyter && \
    touch /root/.jupyter/enterpoint.sh && \
    chmod +x /root/.jupyter/enterpoint.sh

# =========================================================
# Clean Up Unused Files (Consistent with install.sh)
# =========================================================
RUN rm -rf /tmp/* ~/.bash_history && \
    rm -rf /workspace/OmniTraining/.git && \
    rm -rf /workspace/OmniTraining/build.sh && \
    rm -rf /workspace/OmniTraining/ci.yml && \
    rm -rf /workspace/OmniTraining/docker/ci && \
    rm -rf /workspace/AIAK-Megatron/.git && \
    rm -rf /workspace/AIAK-Megatron/.github && \
    rm -rf /workspace/AIAK-Megatron/output && \
    rm -rf /workspace/*.tar.gz && \
    rm -f /workspace/README.md /workspace/license.txt && \
    rm -rf /workspace/docker-examples /workspace/tutorials /workspace/lerobot

WORKDIR /workspace