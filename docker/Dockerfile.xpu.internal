ARG BASE_IMAGE="iregistry.baidu-int.com/xmlir/xmlir_ubuntu_2004_x86_64:v0.33"
FROM ${BASE_IMAGE}

# =========================================================
# Build Arguments
# =========================================================
ARG INSTALL_LEROBOT="false"
ARG XPYTORCH_URL_ARG=""

WORKDIR /workspace

# =========================================================
# Base System Configuration + APT Source Replacement
# =========================================================
COPY ./AIAK-Training-Omni /workspace/OmniTraining
COPY ./AIAK-Megatron /workspace/AIAK-Megatron
SHELL ["/bin/bash", "-c"]

# ======================== Basic Environment Setup ========================
RUN set -exuo pipefail && \
    clean_pip_config() { \
        rm -rf /opt/conda/pip.conf /root/.config/pip/pip.conf /root/.pip/pip.conf \
            /etc/pip.conf /etc/xdg/pip/pip.conf /usr/pip.conf; \
    }; \
    install_pip_config() { \
        mkdir -p /tmp && chmod -R 777 /tmp && \
        if [ -f /workspace/OmniTraining/docker/pip.conf ]; then \
            cp /workspace/OmniTraining/docker/pip.conf /etc/pip.conf && \
            cp /workspace/OmniTraining/docker/pip.conf /usr/pip.conf && \
            mkdir -p /root/.pip && cp /workspace/OmniTraining/docker/pip.conf /root/.pip/pip.conf && \
            mkdir -p /etc/xdg/pip && cp /workspace/OmniTraining/docker/pip.conf /etc/xdg/pip/pip.conf; \
        fi; \
    }; \
    remove_pip_constraints() { \
        source_file="/etc/pip/constraint.txt" && \
        if [ -f "${source_file}" ]; then \
            backup_file="${source_file%.*}_backup.${source_file##*.}" && \
            mv -v "${source_file}" "${backup_file}" && \
            > "${source_file}"; \
        fi; \
    }; \
    setup_system_env() { \
        if [ -f /workspace/OmniTraining/docker/sources.list ]; then \
            rm -rf /etc/apt/sources.list && \
            cp /workspace/OmniTraining/docker/sources.list /etc/apt/sources.list; \
        fi && \
        rm -f /etc/apt/sources.list.d/ubuntu.sources && \
        apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y tzdata && \
        ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
        apt-get install -y bc tree pwgen nodejs iproute2; \
    }; \
    clean_pip_config && \
    install_pip_config && \
    remove_pip_constraints && \
    setup_system_env

# ======================== Install XPU Requirements ========================
RUN set -exuo pipefail && \
    download_xpytorch() { \
        local XPYTORCH_URL=$1; \
        local XPYTORCH_FILE=$(basename "${XPYTORCH_URL}"); \
        echo "download xpytorch package: ${XPYTORCH_URL}" && \
        wget "${XPYTORCH_URL}" && \
        bash "${XPYTORCH_FILE}" && \
        rm "${XPYTORCH_FILE}"; \
    }; \
    . /root/miniconda/etc/profile.d/conda.sh && \
    conda activate python310_torch25_cuda && \
    if [ -n "${XPYTORCH_URL_ARG}" ]; then \
        XPYTORCH_URL="${XPYTORCH_URL_ARG}"; \
        echo "use specified xpytorch version: ${XPYTORCH_URL}"; \
    else \
        xpytorch_info="/workspace/OmniTraining/xpytorch_info.txt"; \
        if [ ! -f "${xpytorch_info}" ]; then \
            echo "xpytorch info file not exist: ${xpytorch_info}" && exit 1; \
        fi; \
        DEFAULT_XPYTORCH_URL=$(cat "${xpytorch_info}" | tr -d '[:space:]'); \
        if [ -z "${DEFAULT_XPYTORCH_URL}" ]; then \
            echo "Error: xpytorch_info.txt file content is empty" && exit 1; \
        fi; \
        XPYTORCH_URL="${DEFAULT_XPYTORCH_URL}"; \
        echo "use default xpytorch version: ${XPYTORCH_URL}"; \
    fi && \
    download_xpytorch "${XPYTORCH_URL}"

# ======================== Install Base Requirements ========================
RUN set -exuo pipefail && \
    install_requirements() { \
        local requirements_file="/workspace/OmniTraining/requirements_xpu.txt" && \
        . /root/miniconda/etc/profile.d/conda.sh && \
        conda activate python310_torch25_cuda && \
        # for deepspeed cpu adam
        DS_BUILD_CPU_ADAM=1  BUILD_UTILS=1  pip install deepspeed==0.18.5 -U -i http://pip.baidu.com/pypi/simple --trusted-host pip.baidu.com && \
        echo "alias ll='ls -alF'" > /etc/profile.d/alias.sh; \
        echo "source /etc/profile.d/alias.sh" >> ~/.bashrc && \
        cd /workspace/OmniTraining/ && \
        pip install -q --no-cache-dir --root-user-action=ignore -r ${requirements_file} \
            -i http://mirrors.baidubce.com/pypi/simple --trusted-host mirrors.baidubce.com; \
    }; \
    install_requirements

# =========================================================
# Megatron / Lerobot
# =========================================================
RUN set -exuo pipefail && \
    install_megatron() { \
        local megatron_dir=/workspace/AIAK-Megatron; \
        local MEGATRON_TAGS="core_v0.15.0" && \
        echo "Installing Megatron-LM ${MEGATRON_TAGS}..." && \
        cd /workspace && \
        wget -q https://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/omni_training/ngc2506_torch28_cuda129_tev29/mcore_v0.15.0/megatron.tar.gz && \
        tar -zxf megatron.tar.gz && \
        mv Megatron-LM AIAK-Megatron && \
        cd ${megatron_dir} && \
        git config --global --add safe.directory ${megatron_dir}; \
        git restore . && \
        if [ -f "/workspace/OmniTraining/tools/apply_patches/apply_two_repo.sh" ]; then \
            bash /workspace/OmniTraining/tools/apply_patches/apply_two_repo.sh \
                /workspace/OmniTraining/patches/Megatron-LM_${MEGATRON_TAGS#core_} \
                ${megatron_dir}; \
        fi && \
        echo "Megatron-LM setup completed"; \
    }; \
    install_lerobot() { \
        echo "Installing lerobot..." && \
        cd /workspace && \
        if [ -d "lerobot" ]; then \
            rm -rf lerobot; \
        fi && \
        mkdir lerobot && \
        cd lerobot && \
        wget http://ai-data.bj.bcebos.com/lerobotv0.4.3.tar.gz && \
        tar -zxf lerobotv0.4.3.tar.gz && \
        if [ -f "requirements-ubuntu.txt" ]; then \
            sed -i '/evdev/d' requirements-ubuntu.txt; \
        fi && \
        pip install func_timeout pytest-xdist prettytable==3.11.0 peft==0.17.0 scipy==1.14.1 && \
        sed -i -e '/"torch[>=<]/d' \
           -e 's/"torchvision[^"]*",/"torchvision==0.20.1",/' \
           -e '/python-can/d' \
           -e '/lerobot\[can-dep\]/d' \
           -e '/lerobot\[damiao\]/d' \
           -e '/unitree_g1 = \[/,/\]/ { /matplotlib/d; /pin/d; /meshcat/d; /casadi/d; }' \
           -e '/lerobot-setup-can/d' \
           -e '/\[tool.setuptools.package-data\]/d' \
           -e '/lerobot = \["envs\/\*\.json"\]/d' \
           -e '/"OT_VALUE"/d' \
           pyproject.toml && \
        pip install "transformers@http://aihc-ai-datasets-bj.bj.bcebos.com/hac-aiacc/aiak-training-llm/transformers-fix-lerobot_openpi-20251001-dcddb970.tar.gz" && \
        pip install --no-build-isolation -e . && \
        sed -i 's|tokenizer_name="google/paligemma-3b-pt-224",|tokenizer_name=config.tokenizer_name,|g' ./src/lerobot/policies/pi05/processor_pi05.py && \
        #FUSED_ADAM_PY=$(python -c "import transformer_engine; import os; print(os.path.join(os.path.dirname(transformer_engine.__file__), 'pytorch/optimizers/fused_adam.py'))") && \
        #sed -i '/#[[:space:]]*tensor_lists = \[g_of_f32_model/,/^[[:space:]]*)/ { \
        #s|^\([[:space:]]*\)#[[:space:]]*\(tensor_lists = \[g_of_f32_model\)|\1\2|; \ 
        #s|^\([[:space:]]*\)#[[:space:]]*\(apply_multi_tensor_adam\)|\1\2|; \
        #/adamw(/,/^[[:space:]]*)/ s|^[[:space:]]*[^#]|#&|; \
        #}' "${FUSED_ADAM_PY}" && \
        echo "Lerobot installation completed"; \
    }; \
    . /root/miniconda/etc/profile.d/conda.sh && \
    conda activate python310_torch25_cuda && \
    install_megatron && \
    if [ "$INSTALL_LEROBOT" = "true" ]; then \
        install_lerobot; \
    else \
        echo "Skipping lerobot installation (INSTALL_LEROBOT=${INSTALL_LEROBOT})"; \
    fi

# =========================================================
# Jupyter Configuration
# =========================================================
RUN mkdir -p /root/.jupyter && \
    touch /root/.jupyter/enterpoint.sh && \
    chmod +x /root/.jupyter/enterpoint.sh

# =========================================================
# Clean Up Unused Files (Consistent with install.sh)
# =========================================================
RUN rm -rf /tmp/* ~/.bash_history && \
    rm -rf /workspace/OmniTraining/.git && \
    rm -rf /workspace/OmniTraining/build.sh && \
    rm -rf /workspace/OmniTraining/ci.yml && \
    rm -rf /workspace/OmniTraining/docker/ci && \
    rm -rf /workspace/AIAK-Megatron/.git && \
    rm -rf /workspace/AIAK-Megatron/.github && \
    rm -rf /workspace/AIAK-Megatron/output && \
    rm -rf /workspace/*.tar.gz && \
    rm -f /workspace/README.md /workspace/license.txt && \
    rm -rf /workspace/docker-examples /workspace/tutorials

WORKDIR /workspace