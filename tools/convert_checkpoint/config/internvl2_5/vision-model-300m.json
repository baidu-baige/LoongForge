{
    "args": {
        "common": {
            "num_layers": 24,
            "hidden_size": 1024,
            "ffn_hidden_size": 4096,
            "num_attention_heads": 16,
            "num_key_value_heads": 16
        },
        "mcore": {
            "use_rotary_position_embeddings": false,
            "transpose_mlp_dense": false,
            "transpose_query_key_value": true
        }
    },
    "name_map": {
        "huggingface": {
            "transformer": "vision_model.encoder",
            "layer_prefix": "layers",
            "input_layernorm": "norm1",
            "attention.query_key_value": "attn.qkv",
            "attention.dense": "attn.proj",
            "post_attention_layernorm": "norm2",
            "post_attention_layerscale": {
                "name": "ls1",
                "is_direct_name": true
            },
            "mlp.dense_h_to_4h": "mlp.fc1",
            "mlp.dense_4h_to_h": "mlp.fc2",
            "post_mlp_layerscale": {
                "name": "ls2",
                "is_direct_name": true
            }
        },
        "mcore": {
            "transformer": "model",
            "layer_prefix": "vision_model.encoder.layers",
            "input_layernorm": {
                "name": "self_attention.linear_qkv",
                "is_layernorm": true
            },
            "attention.query_key_value": {
                "name": "self_attention.linear_qkv",
                "extra": true
            },
            "attention.dense": {
                "name": "self_attention.linear_proj",
                "extra": true
            },
            "post_attention_layernorm": {
                "name": "mlp.linear_fc1",
                "is_layernorm": true
            },
            "post_attention_layerscale": "post_attention_layerscale",
            "mlp.dense_h_to_4h": {
                "name": "mlp.linear_fc1",
                "extra": true
            },
            "mlp.dense_4h_to_h": {
                "name": "mlp.linear_fc2",
                "extra": true
            },
            "post_mlp_layerscale": "post_mlp_layerscale",
            "transformer_tpl": "model%d"
        }
    },
    "torch_dtype": "bfloat16"
}