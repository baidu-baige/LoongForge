            },
            "attention.query_key_value": {
                "name": "self_attention.linear_qkv.language_linear",
                "extra": true
            },
            "attention.dense": {
                "name": "self_attention.linear_proj.language_linear",
                "extra": true
            },
            "post_attention_layernorm": {
                "name": "mlp.linear_fc1.language_linear",
                "is_layernorm": true
            },
            "mlp.dense_h_to_4h": {
                "name": "mlp.linear_fc1.language_linear",
                "extra": true
            },
            "mlp.dense_4h_to_h": {
                "name": "mlp.linear_fc2.language_linear",
                "extra": true
            },
            "final_layernorm": "language_model.decoder.final_layernorm",
            "word_embeddings_for_head": "language_model.output_layer",
            "transformer_tpl": "model%d"
        }
    },
    "torch_dtype": "bfloat16"
