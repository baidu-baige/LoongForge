{
    "args": {
        "common": {
            "num_layers": 32,
            "hidden_size": 4096,
            "ffn_hidden_size": 14336,
            "max_sequence_length": 8192,
            "num_attention_heads": 32,
            "num_key_value_heads": 8,
            "max_position_embeddings": 8192,
            "vocab_size": 128256
        },
        "mcore": {
            "untie_embeddings_and_output_weights": true,
            "use_rotary_position_embeddings": true,
            "add_embedding_padding": true,
            "transpose_mlp_dense": true,
            "transpose_query_key_value": true,
            "rotary_base": 500000
        }
    },
    "name_map": {
        "huggingface": {
            "word_embeddings": "model.embed_tokens",
            "transformer": "model",
            "layer_prefix": "layers",
            "input_layernorm": "input_layernorm",
            "attention.rotary_emb.inv_freq": "self_attn.rotary_emb.inv_freq",
            "attention.query_key_value": "self_attn.language_expert_query_key_value",
            "attention.dense": "self_attn.language_expert_dense",
            "post_attention_layernorm": "post_attention_layernorm",
            "mlp.dense_h_to_4h": [
                "mlp.language_mlp.gate_proj",
                "mlp.language_mlp.up_proj"
            ],
            "mlp.dense_4h_to_h": "mlp.language_mlp.down_proj",
            "final_layernorm": "model.norm",
            "word_embeddings_for_head": "lm_head"
        },
        "mcore": {
            "word_embeddings": "language_model.embedding.word_embeddings",
            "transformer": "model",
            "layer_prefix": "language_model.decoder.layers",
            "input_layernorm": {
                "name": "self_attention.linear_qkv.language_linear",
