+    def _build_fp32_param_set(self, module):
+        """
+        Build a set containing all Parameters and Buffers whose names match one of the patterns
+        in `self.keep_fp32_params`.
+        """
+        fp32_set = set()
+        
+        if not self.keep_fp32_params:
+            return fp32_set
+
+        import re
+        compiled_patterns = [re.compile(pattern) for pattern in self.keep_fp32_params]
+
+        for name, param in module.named_parameters():
+            for pattern in compiled_patterns:
+                if pattern.match(name):
+                    fp32_set.add(param)
+                    logger.info(f"Parameter '{name}' will be kept in FP32")
+                    break
+        
+        if hasattr(module, "named_buffers"):
+            for name, buffer in module.named_buffers():
+                for pattern in compiled_patterns:
+                    if pattern.match(name):
+                        fp32_set.add(buffer)
+                        logger.info(f"Buffer '{name}' will be kept in FP32")
+                        break
+        
+        return fp32_set
+
+    def _convert_with_exclusions(self, module, target_dtype):
+        """convert the entire module except those parameters listed in self.keep_fp32_params"""
+        if target_dtype == torch.float16:
+            converted = module.half()
+        else:
+            converted = module.bfloat16()
+
+        self._restore_fp32_parameters(converted)
+        return converted
+
+    def _restore_fp32_parameters(self, module):
+        """Restores original dtypes of parameters stored in self.fp32_param_set"""
+        if len(self.fp32_param_set) == 0:
+            return
+
+        for _, param in module.named_parameters():
+            if param in self.fp32_param_set and param.dtype != torch.float32:
+                param.data = param.data.to(torch.float32)
+        
+        if hasattr(module, "named_buffers"):
+            for _, buffer in module.named_buffers():
+                if buffer in self.fp32_param_set and buffer.dtype != torch.float32:
+                    buffer.data = buffer.data.to(torch.float32)
+
