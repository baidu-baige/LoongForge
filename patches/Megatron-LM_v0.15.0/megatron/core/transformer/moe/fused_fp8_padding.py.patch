+"""FP8 Padding API"""
+
+import torch
+from typing import List
+from transformer_engine.pytorch.jit import no_torch_dynamo
+from transformer_engine.pytorch.constants import TE_DType
+try:
+    from aiak_fp8_quantizer import (
+        pad_and_dequant,
+        unpadding,
+    )
+    HAVE_FUSED_FP8_PACK = True
+except ImportError:
+    HAVE_FUSED_FP8_PACK = False
+    print(
+        "fail to import aiak_fp8_quantizer, please install baidu/hac-aiacc/AIAK-FP8-Quantization"
+    )
+
+class _FusedFp8Padding(torch.autograd.Function):
+    """functional FP8 padding"""
+
+    @staticmethod
+    def forward(
+        ctx,
+        inp: torch.Tensor,
+        m_splits: List[int],
+        align_size: int,
+        is_grad_enabled: bool,
+    ):
+        """forward functional for padding&dequant fp8"""
+        fp8_tuple = (inp._rowwise_data, inp._rowwise_scale_inv.T.contiguous())
+        out = None
+        if HAVE_FUSED_FP8_PACK:
+            out = pad_and_dequant(fp8_tuple, m_splits, align_size)
+
+        if is_grad_enabled:
+            ctx.m_splits = m_splits
+            ctx.align_size = align_size
+            ctx.requires_dgrad = inp.requires_grad
+
+        return out
+
+    @staticmethod
+    def test_backward_test(ctx, grad_output: torch.Tensor):
+        # pylint: disable=missing-function-docstring
+        padded_m_splits = [
+            (m + ctx.align_size - 1) // ctx.align_size * ctx.align_size for m in ctx.m_splits
+        ]
+
+        grad_input = None
+        if ctx.requires_dgrad:
+            grad_output = grad_output.contiguous()
+
+            grad_output_mats = torch.split(
+                grad_output.view(-1, grad_output.shape[-1]), padded_m_splits
+            )
+            grad_input = torch.cat(
+                [
+                    grad_output_mat[: ctx.m_splits[i]]
+                    for i, grad_output_mat in enumerate(grad_output_mats)
+                ],
+                dim=0,
+            )
+
+        return (grad_input, None, None, None)
+
+    @staticmethod
+    def backward(ctx, grad_output: torch.Tensor):
+        """backward functional for unpadding"""
+        grad_input = None
+        if ctx.requires_dgrad and HAVE_FUSED_FP8_PACK:
+            grad_output = grad_output.contiguous()
+            grad_input = unpadding(grad_output, ctx.m_splits, ctx.align_size)
+        return (grad_input, None, None, None)
+
+
+class FusedFp8Padding(torch.nn.Module):
+    """
+    Apply the padding for Grouped GEMM input.
+
+    Parameters
+    ----------
+    num_gemms: int
+               number of GEMMs to be performed simutaneously.
+    align_size: int, optional
+                the alignment size for the input tensor. If not provided, the alignment size  will
+                be determined by the FP8 recipe, 32 for MXFP8 and 16 for others.
+    """
+
+    def __init__(
+        self,
+        num_gemms: int,
+        align_size: int,
+    ) -> None:
+        super().__init__()
+
+        self.num_gemms = num_gemms
+        self.align_size = align_size
+
+    @no_torch_dynamo()
+    def forward(
+        self,
+        inp: torch.Tensor,
+        m_splits: List[int],
+    ):
+        """
+        Apply the padding to the input.
+
+        Parameters
+        ----------
+        inp : torch.Tensor
+                Input tensor.
+        m_splits : List[int]
+                    List of integers representing the split of the input tensor.
+        """
+
+        assert len(m_splits) == self.num_gemms, "Number of splits should match number of GEMMs."
+
+        # FP8 padding calculate
+        padded_m_splits = [
+            (m + self.align_size - 1) // self.align_size * self.align_size for m in m_splits
+        ]
+        # no padding needed
+        if m_splits == padded_m_splits:
+            return inp, m_splits
+
+        if torch.is_grad_enabled():
+            fn = _FusedFp8Padding.apply
+            args = []
+        else:
+            fn = _FusedFp8Padding.forward
+            args = [None]
+
+        args += (
+            inp,
+            m_splits,
+            self.align_size,
+            torch.is_grad_enabled(),
+        )
+        out = fn(*args)
+
+        return out, padded_m_splits
